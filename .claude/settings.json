{
  "permissions": {
    "allow": [
      "Bash(curl*localhost:5173*)",
      "Bash(curl*localhost:8090*)",
      "Bash(curl*127.0.0.1:5173*)",
      "Bash(curl*127.0.0.1:8090*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["docker"],
    "filesystem": {
      "allowWrite": [
        "~/go/pkg/mod/cache/",
        "~/.cache/go-build/",
        "~/.config/warden/",
        "~/.docker/buildx"
      ]
    },
    "network": {
      "allowedDomains": [
        "localhost:8090",
        "localhost:5173",
        "127.0.0.1:8090",
        "127.0.0.1:5173"
      ],
      "allowUnixSockets": ["/run/user/1000/agent-browser"]
    }
  }
}
